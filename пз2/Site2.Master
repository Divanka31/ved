<%@ Master Language="C#" AutoEventWireup="true" CodeBehind="Site2.master.cs" Inherits="пз2.Site2" %>

<!DOCTYPE html>

<html>
<head runat="server">
<meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>
    <title></title>
    <asp:ContentPlaceHolder id="head" runat="server">
    </asp:ContentPlaceHolder>
    <style type="text/css">
        .auto-style1 {
            width: 100%;
        }
                
        .auto-style5 {
            height: 120px;
        }
        .auto-style6 {
            height: 344px;
            width: 500px;
        }
        .auto-style7 {
            height: 120px;
            width: 500px;
        }
        .auto-style8 {
            height: 344px;
            width: 413px;
            text-align: justify;
            font-family: Cambria, Cochin, Georgia, Times, "Times New Roman", serif;
            font-size: x-large;
            color: #3399FF;
        }
        .auto-style10 {
            height: 344px;
        }
        .auto-style12 {
            width: 100%;
            height: 493px;
        }
        .auto-style13 {
            height: 22px;
        }
        .auto-style14 {
            height: 19px;
        }
        .auto-style16 {
            height: 41px;
            width: 842px;
        }
        .auto-style17 {
            font-size: large;
            color: #0000FF;
        }
        .auto-style18 {
            width: 392px;
            height: 353px;
        }
        .auto-style19 {
            font-size: xx-large;
        }
        .auto-style20 {
            height: 116px;
        }
    </style>
</head>
<body>
    <form id="form1" runat="server">
    <table class="auto-style1">
        <tr>
            <td class="auto-style6" style="text-align: center">
                
                <img alt="а" class="auto-style18" longdesc="а" src="галерея.jpg" /><td class="auto-style8" style="text-align: center; vertical-align: middle;"><span class="auto-style19">Картинная Галерея</span><br />
                <span class="auto-style17">Контактное лицо-Фардзинова-Пхалагаова</span></td>
            <td class="auto-style10">
                <table class="auto-style12">
                    
                </table>
            </td>
        </tr>
        <tr>
            <td class="auto-style7" style="vertical-align: top">
                <table class="auto-style1">
                    <tr>
                        <td style="vertical-align: top; text-align: center">
                            <asp:LinkButton ID="LinkButton1" runat="server" OnClick="LinkButton1_Click">Добавление картины</asp:LinkButton>
                        </td>
                    </tr>
                    <tr>
                        <td style="vertical-align: top; text-align: center">
                            <asp:LinkButton ID="LinkButton2" runat="server" OnClick="LinkButton2_Click">Добавление выставки</asp:LinkButton>
                        </td>
                    </tr>
                    <tr>
                        <td style="vertical-align: top; text-align: center">
                            <asp:LinkButton ID="LinkButton3" runat="server" OnClick="LinkButton3_Click">Состояние заказа</asp:LinkButton>
                        </td>
                    </tr>
                    <tr>
                        <td class="auto-style13" style="vertical-align: top; text-align: center">
                            <asp:LinkButton ID="LinkButton4" runat="server" OnClick="LinkButton4_Click">Изменить картину</asp:LinkButton>
                        </td>
                    </tr>
                    <tr>
                        <td style="vertical-align: top; text-align: center">
                            &nbsp;</td>
                    </tr>
                    <tr>
                        <td style="vertical-align: top; text-align: center">
                            &nbsp;</td>
                    </tr>
                    <tr>
                        <td style="vertical-align: top; text-align: center">
                            &nbsp;</td>
                    </tr>
                    <tr>
                        <td style="vertical-align: top; text-align: center">
                            &nbsp;</td>
                    </tr>
                    <tr>
                        <td style="vertical-align: top; text-align: center">&nbsp;</td>
                    </tr>
                    <tr>
                        <td class="auto-style14" style="vertical-align: top; text-align: center"></td>
                    </tr>
                </table>
            </td>
            <td class="auto-style5" colspan="2" style="vertical-align: top">
                <asp:ContentPlaceHolder ID="ContentPlaceHolder1" runat="server">
                    <p class="auto-style16">
                        &nbsp;</p>
                </asp:ContentPlaceHolder>
            </td>
        </tr>
    </table>
    </form>
    </body>
</html>

